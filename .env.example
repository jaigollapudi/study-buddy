# ──────────────────────────────────────────────────────────────────────────
# Study Buddy configuration. Copy to `.env.local` and tweak as needed.
# Sensible local-first defaults mean it works out of the box with local
# Supabase (Postgres + pgvector) and Ollama.
# ──────────────────────────────────────────────────────────────────────────

# Postgres (vectors + chat history). Default points at local Supabase.
#   Start it with:  npx supabase start   (Studio at http://127.0.0.1:54323)
#   `npx supabase status` prints the values below.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase API — only needed if you use @supabase/supabase-js / Storage.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Text generation provider (only "ollama" is implemented today).
AI_TEXT_PROVIDER=ollama

# Local Ollama server.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Pull these first:  ollama pull llama3.1:8b  &&  ollama pull nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG tuning ──────────────────────────────────────────────────────────────
# Chunk size (chars). 600 keeps one concept per chunk; go smaller for precise
# retrieval, larger for more context per chunk (tradeoff).
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=120
RAG_OPENING_CHUNK_SIZE=300

# Hybrid retrieval (BM25 + vector). Candidate pool before final cap.
RAG_TOP_K=20
RAG_PER_DOC_TOP_K=2
# Final chunks sent to the LLM. 8 = focused; raise to 12 for broad topics.
RAG_MAX_CONTEXT_CHUNKS=8
# Minimum cosine similarity 0–100 (25 = 0.25). Rejects noisy low-score chunks.
RAG_MIN_SIMILARITY=25

# Embedding batch size (lower if Ollama runs out of memory).
RAG_EMBED_BATCH=32
MAX_UPLOAD_BYTES=104857600

# Podcast text-to-speech:
#   browser = free, uses the Web Speech API on the client (default)
#   gemini  = higher quality, requires GEMINI_API_KEY below (paid)
TTS_PROVIDER=browser
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
